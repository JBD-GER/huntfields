# Public app URL. Use https://www.huntfields.com in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Resend transactional email. Sender domain must be verified in Resend.
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM=Huntfields <notifications@your-domain.com>
ADMIN_NOTIFICATION_EMAIL=ops@your-domain.com

# Maps
NEXT_PUBLIC_MAP_STYLE_URL=https://demotiles.maplibre.org/style.json
NEXT_PUBLIC_MAPBOX_TOKEN=

# Stripe Checkout, Connect payouts, Identity, Tax, Customer Portal, and webhooks
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
# Stripe webhook endpoint:
#   Local:      http://localhost:3000/api/stripe/webhook
#   Production: https://www.huntfields.com/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# OpenAI listing image/description assistance
OPENAI_API_KEY=sk-proj-your-openai-key
OPENAI_TEXT_MODEL=gpt-5-mini
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_SIZE=1536x1024
OPENAI_IMAGE_QUALITY=high
OPENAI_IMAGE_OUTPUT_FORMAT=jpeg
