NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Auth providers are configured in Supabase, not with browser env vars:
# - Google: Supabase Dashboard -> Auth -> Providers -> Google
# - SAML 2.0: Supabase Dashboard -> Auth -> Providers -> SAML 2.0,
#   then add IdP connections with the Supabase CLI.
# - Passkeys: Supabase Dashboard -> Auth -> Providers -> Passkeys.

# Resend transactional email
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM=Huntfields <notifications@your-domain.com>
ADMIN_NOTIFICATION_EMAIL=ops@your-domain.com

# OpenAI image generation for listing covers. The key must stay server-side.
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5-mini
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_SIZE=1536x1024
OPENAI_IMAGE_QUALITY=high
OPENAI_IMAGE_OUTPUT_FORMAT=jpeg

# Optional map provider. The default MapLibre style does not require a key.
NEXT_PUBLIC_MAP_STYLE_URL=https://demotiles.maplibre.org/style.json
NEXT_PUBLIC_MAPBOX_TOKEN=

# Optional Stripe-ready provider. MVP falls back to manual/noop payments without this.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# If using Supabase Auth email confirmations through Resend SMTP, configure these
# in the Supabase dashboard:
# SMTP host: smtp.resend.com
# SMTP port: 465
# SMTP user: resend
# SMTP pass: RESEND_API_KEY
